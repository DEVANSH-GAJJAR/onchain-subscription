{
  "name": "onchain-subscription",
  "version": "1.0.0",
  "description": "ETH-based on-chain subscription smart contract with Hardhat tooling",
  "scripts": {
    "compile":        "hardhat compile",
    "test":           "hardhat test",
    "test:gas":       "REPORT_GAS=true hardhat test",
    "coverage":       "hardhat coverage",
    "deploy:local":   "hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "node":           "hardhat node",
    "clean":          "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.0.0",
    "hardhat": "^2.22.0"
  },
  "keywords": ["solidity", "ethereum", "subscription", "smart-contract", "hardhat"],
  "license": "MIT"
}
